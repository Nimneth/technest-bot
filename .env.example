# ─────────────────────────────────────────────
#  WhatsApp AI Chatbot — Environment Variables
# ─────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# WhatsApp Cloud API
WHATSAPP_TOKEN=your_whatsapp_cloud_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_VERIFY_TOKEN=technest_verify_2024
WHATSAPP_API_VERSION=v25.0

# Google Gemini API (free at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Admin Notifications
ADMIN_PHONE_NUMBER=94771234567

# Chat History
HISTORY_STORAGE=memory

# Escalation
MAX_TURNS_BEFORE_SUGGEST_ESCALATION=10
